@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap');

:root {
    /* Color Palette derived from SINAG and PUP logos */
    --primary: #F26522;
    /* SINAG Orange */
    --primary-light: #ff8c52;
    --secondary: #FBA127;
    /* SINAG Gold */
    --accent: #800000;
    /* PUP Maroon */
    --dark: #0f0f0f;
    --dark-muted: #1a1a1a;
    --light: #ffffff;
    --light-muted: #f5f5f5;
    --glass: rgba(255, 255, 255, 0.05);
    --glass-border: rgba(255, 255, 255, 0.1);

    /* Spacing */
    --space-xs: 0.5rem;
    --space-sm: 1rem;
    --space-md: 2rem;
    --space-lg: 4rem;
    --space-xl: 8rem;

    /* Transitions */
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background-color: var(--dark);
    color: var(--light);
    line-height: 1.6;
    overflow-x: hidden;
}

h1,
h2,
h3,
h4 {
    font-weight: 800;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
}

a {
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
}

ul {
    list-style: none;
}

img {
    max-width: 100%;
    display: block;
}

/* Layout Utilities */
.container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 var(--space-md);
}

.section-padding {
    padding: var(--space-lg) 0;
}

/* Premium Button */
.btn {
    display: inline-block;
    padding: 1rem 2rem;
    border-radius: 4px;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    border: none;
    transition: var(--transition);
}

.btn-primary {
    background-color: var(--primary);
    color: var(--light);
}

.btn-primary:hover {
    background-color: var(--secondary);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(242, 101, 34, 0.3);
}

/* Header & Nav */
header {
    height: 120px; /* Increased for better fit */
    display: flex;
    align-items: center;
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    background: linear-gradient(to right, #ffffff, var(--primary));
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

nav {
    display: flex;
    justify-content: flex-start; /* Changed to start to allow margins to work */
    align-items: center;
    width: 100%;
    padding: 1.5rem 10rem 0.5rem 2rem; /* Adjusted: less padding on left for buttons, more on right to balance */
}

.logo-group {
    display: flex;
    align-items: center;
    gap: 1.2rem;
}

.pup-logo {
    height: 50px;
}

.sinag-logo {
    height: 60px;
}

.brand-info h1 {
    font-size: 0.9rem; /* Reduced for long name */
    margin: 0;
    color: var(--dark);
    white-space: nowrap;
}

.brand-info span {
    font-size: 0.6rem; /* Reduced for long name */
    display: block;
    color: var(--dark-muted);
    font-weight: 600;
    white-space: nowrap;
}

.nav-links {
    display: flex;
    gap: 1.5rem; /* Reduced gap to accommodate long title */
}

.nav-links a {
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--dark);
    opacity: 0.85;
}

.nav-links a:hover,
.nav-links a.active {
    opacity: 1;
    color: var(--primary);
}

/* Navigation Anchoring */
.nav-links {
    margin-left: 6rem; /* Gap from branding */
}

/* Auth Buttons */
.auth-btns {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-right: auto; /* Pushes everything else to the far right */
}

.btn-link {
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dark);
    opacity: 0.8;
}

.btn-link:hover {
    color: var(--primary);
    opacity: 1;
}

/* Hero Section */
.hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 120px; /* Matched to new header height */
    background-image: linear-gradient(to right, rgba(255, 255, 255, 0.5), rgba(242, 101, 34, 0.5)), url('Assets/PUP CABIAO.JPG');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
}

.hero-content {
    max-width: 800px;
}

.hero span {
    color: var(--primary);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.9rem;
    display: block;
    margin-bottom: 1rem;
}

.hero h2 {
    font-size: clamp(3rem, 8vw, 5rem);
    margin-bottom: 2rem;
    color: var(--dark);
}

.hero p {
    font-size: 1.1rem;
    color: var(--dark-muted);
    margin-bottom: 3rem;
    max-width: 600px;
    font-weight: 500;
}

/* Featured News */
.news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--space-md);
}

.article-card {
    background: var(--dark-muted);
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    overflow: hidden;
    transition: var(--transition);
}

.article-card:hover {
    transform: translateY(-10px);
    border-color: var(--primary);
}

.article-image {
    height: 240px;
    background-color: #222;
    overflow: hidden;
}

.article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition);
}

.article-card:hover .article-image img {
    transform: scale(1.1);
}

.article-info {
    padding: var(--space-md);
}

.article-meta {
    font-size: 0.8rem;
    color: var(--primary);
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
}

.article-info h3 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
}

.article-info p {
    font-size: 0.95rem;
    color: var(--light-muted);
    margin-bottom: 1.5rem;
}

/* Footer */
footer {
    background: #050505;
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--glass-border);
}

.footer-content {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-md);
}

.footer-brand h4 {
    color: var(--primary);
    margin-bottom: 1rem;
}

/* Animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.animate-up {
    animation: fadeInUp 0.8s ease forwards;
}

/* Responsive */
@media (max-width: 968px) {
    .nav-links {
        display: none;
    }

    .hero h2 {
        font-size: 3rem;
    }
}